DJANGO_ENV=production
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=api.example.com
FIELD_ENCRYPTION_KEYS=prod-2026-04:replace-with-fernet-key
FIELD_ENCRYPTION_PRIMARY_KEY_ID=prod-2026-04

DB_ENGINE=django.db.backends.postgresql
DB_NAME=gamesbazaar
DB_USER=gamesbazaar_user
DB_PASSWORD=replace-with-database-password
DB_HOST=replace-with-database-host
DB_PORT=5432
# Seconds to keep database connections alive between requests (0 disables).
DB_CONN_MAX_AGE=60

# Error monitoring (strongly recommended). Create a free Sentry project and
# paste its DSN here; leave empty to disable.
SENTRY_DSN=
# Fraction of requests to trace for performance monitoring (0 disables).
SENTRY_TRACES_SAMPLE_RATE=0

CORS_ALLOWED_ORIGINS=https://www.example.com
CSRF_TRUSTED_ORIGINS=https://www.example.com
WEBSOCKET_ALLOWED_ORIGINS=https://www.example.com

EMAIL_BACKEND=core.email_backends.DKIMSMTPEmailBackend
EMAIL_HOST=relay.mailbaby.net
EMAIL_PORT=587
EMAIL_HOST_USER=replace-with-mailbaby-user
EMAIL_HOST_PASSWORD=replace-with-mailbaby-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=GamesBazaar <noreply@gamesbazaar.pk>
DKIM_DOMAIN=gamesbazaar.pk
DKIM_SELECTOR=gb1
DKIM_PRIVATE_KEY_PATH=secrets/dkim_private.pem

CLOUDFLARE_R2_ENABLED=True
CLOUDFLARE_R2_BUCKET_NAME=replace-with-r2-bucket-name
CLOUDFLARE_R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
CLOUDFLARE_R2_ENDPOINT_URL=https://replace-with-account-id.r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL_EXPIRATION_SECONDS=86400
CLOUDFLARE_R2_PRIVATE_URL_EXPIRATION_SECONDS=300

CHANNEL_REDIS_URL=redis://replace-with-redis-host:6379/0
CACHE_REDIS_URL=redis://replace-with-redis-host:6379/1
JWT_AUTH_COOKIE_SECURE=True
JWT_AUTH_COOKIE_SAMESITE=Lax
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Optional: restrict /admin/ to known IPs/CIDR ranges.
# ADMIN_ALLOWED_IPS=203.0.113.10,198.51.100.0/24
# ADMIN_TRUSTED_PROXY_IPS=127.0.0.1

# JazzCash MWallet gateway (REST API v1.1). Payments stay hidden until all
# four required values are set. Credentials come from the JazzCash merchant
# portal (Integration > Credentials); register the Return URL and the IPN URL
# (https://api.example.com/api/payments/jazzcash/ipn/) there as well.
# Schedule alongside the other cron jobs:
#   python manage.py reconcile_jazzcash_payments   (every 10-15 minutes)
JAZZCASH_MERCHANT_ID=replace-with-merchant-id
JAZZCASH_PASSWORD=replace-with-integration-password
JAZZCASH_INTEGRITY_SALT=replace-with-integrity-salt
JAZZCASH_RETURN_URL=https://www.example.com/wallet
# Optional: sanity ceiling for one JazzCash purchase charge in PKR (default 1000000).
# JAZZCASH_MAX_PAYMENT_PKR=1000000
# Optional: floor for one JazzCash charge in PKR (default 20). A direct buy is
# charged the exact wallet shortfall; anything under this floor is lifted to it
# and the difference stays in the buyer's wallet. Raise it if the gateway starts
# declining small amounts.
# JAZZCASH_MIN_PAYMENT_PKR=20
# Optional: only needed for the Refund API.
# JAZZCASH_MERCHANT_MPIN=replace-with-merchant-mpin
# JAZZCASH_BASE_URL=https://pgw.jazzcash.com.pk
# JAZZCASH_TXN_REF_PREFIX=Gam
# Optional: pp_SubMerchantName (default GamesBazaar). Letters only — no spaces
# or symbols; anything else is stripped out before the request is signed.
# JAZZCASH_SUB_MERCHANT_NAME=GamesBazaar
