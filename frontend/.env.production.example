NEXT_PUBLIC_SITE_URL=https://www.example.com
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_WS_URL=wss://api.example.com
NEXT_PUBLIC_IMAGE_HOSTS=account-id.r2.cloudflarestorage.com,cdn.example.com
SECURE_HSTS_PRELOAD=True
# Google sign-in (same client id the backend uses).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
# Frontend error monitoring (create a separate Sentry project, platform
# Next.js, and paste its DSN). Leave empty to disable.
NEXT_PUBLIC_SENTRY_DSN=
# Google Analytics 4 Measurement ID (Admin > Data Streams, looks like
# G-XXXXXXXXXX). Leave empty to disable.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Meta Pixel ID (Meta Events Manager > Data Sources, a long number).
# Leave empty to disable.
NEXT_PUBLIC_META_PIXEL_ID=
